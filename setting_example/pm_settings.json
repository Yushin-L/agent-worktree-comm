{
  "defaultMode": "acceptEdits",
  "additionalDirectories": [
    "../agent-worktree-comm"
  ],
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "Monitor",
      "Bash(*)"
    ],
    "deny": [
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push --mirror *)",
      "Bash(git push * --delete *)",
      "Bash(git push * :*)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git branch -D *)",
      "Bash(git filter-branch *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr close *)",
      "Bash(gh repo delete *)",
      "Bash(gh release delete *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(npm install *)",
      "Bash(npm i *)",
      "Bash(go get *)",
      "Bash(go install *)",
      "Bash(pip install *)",
      "Bash(go test *)",
      "Bash(npm test *)",
      "Bash(vitest *)",
      "Bash(jest *)",
      "Bash(pytest *)",
      "Bash(docker compose up *)",
      "Bash(docker compose run *)",
      "Bash(docker compose exec *)",
      "Bash(docker system prune *)",
      "Bash(docker volume rm *)",
      "Bash(docker rmi *)",
      "Bash(docker kill *)"
    ]
  }
}
